{
    "theme": "Gruvbox Dark",
    "ui_font_family": "RecMonoCasual Nerd Font",
    "ui_font_size": 16,
    "buffer_font_family": "RecMonoCasual Nerd Font",
    "buffer_font_size": 16,
    "relative_line_numbers": true,
    "search": {
        "regex": true
    },
    "inlay_hints": {
        "enabled": false
    },
    "terminal": {
        "alternate_scroll": "off",
        "blinking": "terminal_controlled",
        "copy_on_select": false
    },
    "vim_mode": true,
    "vim": {
        "use_system_clipboard": "always",
        "use_multiline_find": true, // default: false
        "use_smartcase_find": true // default: false
    },
    "tab_size": 4,
    "soft_wrap": "preferred_line_length",
    "preferred_line_length": 100,
    "languages": {
        "JSDoc": {
            "tab_size": 4
        },
        "JavaScript": {
            "tab_size": 4
        },
        "JSON": {
            "tab_size": 4
        },
        "HTML": {
            "tab_size": 4
        },
        "CSS": {
            "tab_size": 4
        },
        "Go": {
            "tab_size": 4
        },
        "Make": {
            "tab_size": 4
        },
        "Markdown": {
            "tab_size": 4,
            "formatter": "prettier"
        },
        "yaml": {
            "tab_size": 4,
            "formatter": "prettier"
        }
    },
    "experimental.theme_overrides": {
        "background.appearance": "transparent",
        "background": "#00000075",
        "editor.background": "#00000000",
        "editor.gutter.background": "#00000000",
        "tab_bar.background": "#00000000",
        "terminal.background": "#00000000",
        "toolbar.background": "#00000000",
        "tab.active_background": "#00000000",
        "tab.inactive_background": "#00000000",
        "status_bar.background": "#00000090",
        "title_bar.background": "#00000090",
        "panel.background": "#00000000",
        "border.variant": "#00000000",
        "scrollbar.track.border": "#00000000",
        "editor.active_line.background": "#00000065"
    }
}
